// Prisma schema for Support Desk
// PostgreSQL database with comprehensive data model for helpdesk functionality

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Authentication & Users
// ============================================================================

enum UserRole {
  ADMIN
  AGENT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         UserRole @default(AGENT)
  active       Boolean  @default(true)
  signature    String? // Email signature for AI suggestions and replies
  avatarUrl    String?  @map("avatar_url") @db.Text // Profile picture (base64 data URL)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  assignedThreads Thread[]         @relation("AssignedAgent")
  sessions        Session[]
  assignmentRules AssignmentRule[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================================================
// Email / Mailbox
// ============================================================================

enum MailboxProvider {
  ZOHO_IMAP
  ZOHO_API
}

model Mailbox {
  id           String          @id @default(cuid())
  displayName  String          @map("display_name")
  emailAddress String          @unique @map("email_address")
  provider     MailboxProvider @default(ZOHO_IMAP)

  // Sync state - encrypted credentials stored in IntegrationSettings
  lastSyncAt  DateTime? @map("last_sync_at")
  lastSyncUid Int?      @map("last_sync_uid")
  uidValidity Int?      @map("uid_validity")
  syncCursor  String?   @map("sync_cursor") // JSON blob for additional state
  syncError   String?   @map("sync_error")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  threads Thread[]

  @@map("mailboxes")
}

// ============================================================================
// Threads & Messages
// ============================================================================

enum ThreadStatus {
  OPEN
  PENDING
  CLOSED
  TRASHED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

model Thread {
  id        String @id @default(cuid())
  mailboxId String @map("mailbox_id")

  // Provider-specific thread key for deduplication
  providerThreadKey String @map("provider_thread_key")

  // Thread metadata
  subject       String
  customerEmail String  @map("customer_email")
  customerName  String? @map("customer_name")

  // Status and assignment
  status         ThreadStatus @default(OPEN)
  assignedUserId String?      @map("assigned_user_id")

  // Last customer-visible action metadata (refund/replacement/etc.)
  lastActionType String?   @map("last_action_type")
  lastActionAt   DateTime? @map("last_action_at")
  lastActionData Json?     @map("last_action_data")

  // Manual-escalation flag: something couldn't be auto-handled (e.g. an
  // in-production address change) and needs a person. Surfaces in the
  // Needs Attention queue until resolved.
  needsManual      Boolean   @default(false) @map("needs_manual")
  manualReason     String?   @map("manual_reason")
  manualResolvedAt DateTime? @map("manual_resolved_at")

  // Timestamps
  lastMessageAt DateTime @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  mailbox      Mailbox       @relation(fields: [mailboxId], references: [id])
  assignedUser User?         @relation("AssignedAgent", fields: [assignedUserId], references: [id])
  messages     Message[]
  customerLink CustomerLink? @relation(fields: [customerEmail], references: [email])
  tags         ThreadTag[]
  triage       ThreadTriage?
  aiDraft      AiDraft?

  @@unique([mailboxId, providerThreadKey])
  @@index([customerEmail])
  @@index([status])
  @@index([assignedUserId])
  @@index([lastMessageAt])
  // Composite indexes for common query patterns
  @@index([status, assignedUserId])
  @@index([customerEmail, status])
  @@index([status, lastMessageAt])
  @@map("threads")
}

model Message {
  id       String @id @default(cuid())
  threadId String @map("thread_id")

  // Provider message tracking
  providerMessageId String? @unique @map("provider_message_id") // Message-ID header
  imapUid           Int?    @map("imap_uid")

  // Direction and status
  direction MessageDirection
  status    MessageStatus    @default(SENT)

  // Email headers
  fromAddress String   @map("from_address")
  fromName    String?  @map("from_name")
  toAddresses String[] @map("to_addresses") // Array of email addresses
  ccAddresses String[] @map("cc_addresses")
  subject     String

  // Threading headers
  inReplyTo  String?  @map("in_reply_to")
  references String[] @default([])

  // Content
  bodyText String? @map("body_text")
  bodyHtml String? @map("body_html")

  // Timestamps
  sentAt    DateTime @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Read tracking
  isRead Boolean @default(false) @map("is_read")

  // Which agent sent this (outbound only) - for per-agent stats
  sentByUserId String? @map("sent_by_user_id")

  // Retry tracking for outbound
  retryCount Int     @default(0) @map("retry_count")
  lastError  String? @map("last_error")

  // Relations
  thread      Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@index([threadId])
  @@index([sentAt])
  @@map("messages")
}

model Attachment {
  id        String @id @default(cuid())
  messageId String @map("message_id")

  filename  String
  mimeType  String  @map("mime_type")
  size      Int
  contentId String? @map("content_id") // For inline attachments

  // File bytes stored in the DB so any service (web/worker) can serve them and
  // they survive Railway's ephemeral filesystem + redeploys.
  content     Bytes?
  // Legacy local-disk path (older attachments only)
  storagePath String? @map("storage_path")

  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// ============================================================================
// Customer & Order Linking
// ============================================================================

model CustomerLink {
  id    String @id @default(cuid())
  email String @unique

  // Shopify customer data (cached)
  shopifyCustomerId String? @map("shopify_customer_id")
  shopifyData       Json?   @map("shopify_data") // Cached customer info

  lastVerifiedAt DateTime? @map("last_verified_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  threads Thread[]

  @@map("customer_links")
}

enum OrderMatchMethod {
  METAFIELD
  EXTERNAL_ID
  ORDER_NUMBER
  EMAIL_TIME_ITEMS
  MANUAL
}

model OrderLink {
  id String @id @default(cuid())

  shopifyOrderId     String  @unique @map("shopify_order_id")
  shopifyOrderNumber String? @map("shopify_order_number")
  printifyOrderId    String? @map("printify_order_id")

  // Match quality tracking
  matchConfidence Float?            @map("match_confidence") // 0-1 score
  matchMethod     OrderMatchMethod? @map("match_method")

  // Cached data
  shopifyData  Json? @map("shopify_data")
  printifyData Json? @map("printify_data")

  lastSyncAt DateTime? @map("last_sync_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([printifyOrderId])
  @@map("order_links")
}

model PrintifyOrderCache {
  // Printify order ID
  id                     String    @id
  shopId                 String?   @map("shop_id")
  externalId             String?   @map("external_id")
  label                  String?
  metadataShopOrderId    String?   @map("metadata_shop_order_id")
  metadataShopOrderLabel String?   @map("metadata_shop_order_label")
  status                 String
  updatedAt              DateTime? @map("updated_at")
  data                   Json
  // Hash of the order fields the UI reads (status, line-item statuses, shipment
  // tracking/delivered_at). Lets the incremental sync skip re-writing unchanged
  // orders within its window - the Printify list payload has no updated_at to
  // compare against. Nullable so existing rows backfill on first touch.
  contentHash            String?   @map("content_hash")
  lastSyncedAt           DateTime  @default(now()) @map("last_synced_at")
  createdAt              DateTime  @default(now()) @map("created_at")

  @@index([externalId])
  @@index([label])
  @@index([metadataShopOrderId])
  @@index([metadataShopOrderLabel])
  @@index([updatedAt])
  @@index([status, createdAt])
  @@map("printify_orders")
}

model TrackingCache {
  id             String @id @default(cuid())
  trackingNumber String @map("tracking_number")
  carrier        String

  // Cached tracking result data
  data Json

  // Timestamps
  fetchedAt DateTime @default(now()) @map("fetched_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([trackingNumber, carrier])
  @@index([trackingNumber])
  @@map("tracking_cache")
}

// ============================================================================
// Integration Settings
// ============================================================================

enum IntegrationType {
  ZOHO_IMAP_SMTP
  ZOHO_API
  SHOPIFY
  PRINTIFY
  CLAUDE
  SMARTYSTREETS
  META // Facebook/Instagram OAuth tokens
  JUDGEME // Judge.me product reviews
  TRACKINGMORE // TrackingMore shipment tracking API
}

model IntegrationSettings {
  id   String          @id @default(cuid())
  type IntegrationType @unique

  // Encrypted JSON containing all settings for this integration
  encryptedData String @map("encrypted_data")

  enabled      Boolean   @default(false)
  lastTestedAt DateTime? @map("last_tested_at")
  testResult   String?   @map("test_result")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("integration_settings")
}

// ============================================================================
// Sync Jobs (for tracking background sync state)
// ============================================================================

enum SyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model SyncJob {
  id        String @id @default(cuid())
  mailboxId String @map("mailbox_id")

  status      SyncJobStatus @default(PENDING)
  startedAt   DateTime?     @map("started_at")
  completedAt DateTime?     @map("completed_at")

  messagesProcessed Int     @default(0) @map("messages_processed")
  errorMessage      String? @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([mailboxId])
  @@index([status])
  @@map("sync_jobs")
}

// ============================================================================
// Tags & Auto-Tagging Rules
// ============================================================================

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280") // Gray default
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  threads ThreadTag[]
  rules   TagRule[]

  @@map("tags")
}

model ThreadTag {
  threadId  String   @map("thread_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([threadId, tagId])
  @@map("thread_tags")
}

enum TagRuleCondition {
  SUBJECT_CONTAINS
  SUBJECT_STARTS_WITH
  EMAIL_CONTAINS
  EMAIL_DOMAIN
  BODY_CONTAINS
}

enum FilterRuleCondition {
  SUBJECT_CONTAINS
  SUBJECT_STARTS_WITH
  EMAIL_CONTAINS
  EMAIL_DOMAIN
}

model TagRule {
  id        String           @id @default(cuid())
  tagId     String           @map("tag_id")
  condition TagRuleCondition
  value     String // The value to match against
  enabled   Boolean          @default(true)
  createdAt DateTime         @default(now()) @map("created_at")

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("tag_rules")
}

model FilterRule {
  id        String              @id @default(cuid())
  name      String
  condition FilterRuleCondition
  value     String // The value to match against
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now()) @map("created_at")

  @@index([enabled])
  @@map("filter_rules")
}

// ============================================================================
// Assignment Rules
// ============================================================================

enum AssignmentRuleCondition {
  SUBJECT_CONTAINS
  SUBJECT_STARTS_WITH
  EMAIL_CONTAINS
  EMAIL_DOMAIN
  BODY_CONTAINS
  // Time-based conditions
  WEEKDAY // value: comma-separated day numbers (0=Sunday, 1=Monday, etc.)
  TIME_RANGE // value: "HH:MM-HH:MM" format (e.g., "09:00-17:00")
  // Tag-based conditions
  HAS_TAG // value: tag name
}

model AssignmentRule {
  id         String                  @id @default(cuid())
  name       String // Rule name for display
  condition  AssignmentRuleCondition
  value      String // The value to match against
  assignToId String                  @map("assign_to_id")
  priority   Int                     @default(0) // Higher priority rules are checked first
  enabled    Boolean                 @default(true)
  createdAt  DateTime                @default(now()) @map("created_at")

  assignTo User @relation(fields: [assignToId], references: [id], onDelete: Cascade)

  @@index([enabled])
  @@index([priority])
  @@map("assignment_rules")
}

// ============================================================================
// App Settings (global settings)
// ============================================================================

model AppSettings {
  id                           String   @id @default("default")
  autoMergeThreads             Boolean  @default(false) @map("auto_merge_threads")
  autoMergeWindowHours         Int      @default(24) @map("auto_merge_window_hours") // Merge threads within this window
  // Refunds at or above this amount (in cents) require an ADMIN. 0 = agents
  // may issue any refund. Cancellations/replacements are always allowed but
  // logged.
  refundApprovalThresholdCents Int      @default(0) @map("refund_approval_threshold_cents")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// Append-only audit trail of money/order actions. With more than one agent,
// this is the record of who refunded/cancelled/replaced what.
model ActionLog {
  id          String   @id @default(cuid())
  threadId    String?  @map("thread_id")
  userId      String?  @map("user_id")
  userName    String   @map("user_name") // denormalized so it survives user deletion
  action      String // 'refund' | 'cancel_both' | 'create_replacement' | 'discount_adjustment' | ...
  summary     String   @db.Text // human-readable, e.g. "Refunded $44.00 on #16270"
  amountCents Int?     @map("amount_cents")
  orderName   String?  @map("order_name")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([threadId])
  @@map("action_logs")
}

// Reusable canned replies / macros for FAQ answers.
model CannedReply {
  id        String   @id @default(cuid())
  title     String
  category  String?
  body      String   @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("canned_replies")
}

// ============================================================================
// AI Suggestion Feedback (for learning from edits)
// ============================================================================

model SuggestionFeedback {
  id       String @id @default(cuid())
  threadId String @map("thread_id")

  // The original AI-generated draft
  originalDraft String @map("original_draft")

  // The edited version that was actually sent
  editedDraft String @map("edited_draft")

  // Category for grouping similar feedback (e.g., "refund", "tracking", "replacement")
  category String?

  // Tags from the thread at the time of feedback
  threadTags String[] @map("thread_tags")

  // User who made the edit
  userId String @map("user_id")

  // Whether this feedback was used in subsequent prompts
  usedCount Int @default(0) @map("used_count")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([category])
  @@index([createdAt])
  @@map("suggestion_feedback")
}

// ============================================================================
// Social Comments (Facebook + Instagram)
// ============================================================================

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
}

enum SocialAccountType {
  FACEBOOK_PAGE
  INSTAGRAM_BUSINESS
}

enum SocialCommentStatus {
  NEW // Unreviewed
  IN_PROGRESS // Agent is working on it
  DONE // Resolved
  ESCALATED // Needs manager attention
}

enum SocialObjectType {
  POST
  AD
  STORY
  REEL
}

// Connected Facebook Pages and Instagram Business accounts
model SocialAccount {
  id String @id @default(cuid())

  // Platform identification
  platform    SocialPlatform
  accountType SocialAccountType @map("account_type")
  externalId  String            @map("external_id") // FB Page ID or IG Account ID

  // Account info
  name              String // Page/Account name
  username          String? // @username for IG
  profilePictureUrl String? @map("profile_picture_url")

  // OAuth tokens (encrypted, stored separately in IntegrationSettings)
  // This just tracks which accounts are enabled
  accessTokenRef String? @map("access_token_ref") // Reference to encrypted token

  // Webhook config
  webhookEnabled     Boolean @default(false) @map("webhook_enabled")
  webhookVerifyToken String? @map("webhook_verify_token")

  // Sync state
  lastSyncAt DateTime? @map("last_sync_at")
  syncError  String?   @map("sync_error")

  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  objects       SocialObject[]
  comments      SocialComment[]
  conversations SocialConversation[]
  rules         SocialRule[]         @relation("RuleSocialAccounts")

  @@unique([platform, externalId])
  @@index([platform])
  @@index([enabled])
  @@map("social_accounts")
}

// ============================================================================
// Messenger conversations (page DMs)
// ============================================================================

model SocialConversation {
  id        String @id @default(cuid())
  accountId String @map("account_id")

  // Meta conversation id (t_...)
  externalId String @map("external_id")

  // Other participant (the customer)
  participantId   String? @map("participant_id") // PSID for replies
  participantName String  @map("participant_name")

  snippet     String? // last message preview
  unreadCount Int     @default(0) @map("unread_count")
  canReply    Boolean @default(true) @map("can_reply")

  // Meta's 24h standard messaging window is measured from the customer's
  // last message - replies after that are blocked by policy.
  lastCustomerMessageAt DateTime? @map("last_customer_message_at")
  lastMessageAt         DateTime  @map("last_message_at")

  status SocialCommentStatus @default(NEW)

  // Pre-generated AI reply draft
  aiDraft   String?   @map("ai_draft") @db.Text
  aiDraftAt DateTime? @map("ai_draft_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account  SocialAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages SocialMessage[]

  @@unique([accountId, externalId])
  @@index([status])
  @@index([lastMessageAt])
  @@map("social_conversations")
}

model SocialMessage {
  id             String @id @default(cuid())
  conversationId String @map("conversation_id")

  externalId  String  @unique @map("external_id") // Meta message id (m_...)
  fromId      String? @map("from_id")
  fromName    String? @map("from_name")
  isPage      Boolean @default(false) @map("is_page") // sent by us
  message     String  @db.Text
  attachments Json?

  sentAt    DateTime @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")

  conversation SocialConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([sentAt])
  @@map("social_messages")
}

// Posts, Ads, Stories, Reels - the parent object of comments
model SocialObject {
  id        String @id @default(cuid())
  accountId String @map("account_id")

  // Platform identification
  externalId String           @map("external_id") // Post/Ad ID from Meta
  type       SocialObjectType
  permalink  String? // URL to the post/ad

  // Content preview
  message      String? // Post text/caption
  thumbnailUrl String? @map("thumbnail_url") // Image/video thumbnail
  mediaType    String? @map("media_type") // IMAGE, VIDEO, CAROUSEL, etc.

  // Ad context (null for organic posts)
  adId           String? @map("ad_id")
  // Delivery status of the ad (ACTIVE/PAUSED/...) - comments on inactive ads
  // auto-resolve out of the open inbox
  adStatus       String? @map("ad_status")
  adName         String? @map("ad_name")
  adsetId        String? @map("adset_id")
  adsetName      String? @map("adset_name")
  campaignId     String? @map("campaign_id")
  campaignName   String? @map("campaign_name")
  destinationUrl String? @map("destination_url") // Landing page URL

  // Timestamps
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  account  SocialAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  comments SocialComment[]

  @@unique([accountId, externalId])
  @@index([type])
  @@index([adId])
  @@map("social_objects")
}

// Individual comments
model SocialComment {
  id        String @id @default(cuid())
  accountId String @map("account_id")
  objectId  String @map("object_id")

  // Platform identification
  externalId String         @map("external_id") // Comment ID from Meta
  platform   SocialPlatform

  // Thread structure
  parentId     String? @map("parent_id") // Parent comment ID (for replies)
  threadRootId String? @map("thread_root_id") // Top-level comment ID

  // Author info
  authorId         String? @map("author_id") // Meta user ID
  authorName       String  @map("author_name")
  authorUsername   String? @map("author_username")
  authorProfileUrl String? @map("author_profile_url")
  isPageOwner      Boolean @default(false) @map("is_page_owner") // Is this from the page itself

  // Comment content
  message       String
  attachmentUrl String? @map("attachment_url") // Image/sticker URL
  permalink     String? // Direct link to comment

  // Comment state
  hidden    Boolean @default(false)
  deleted   Boolean @default(false)
  canHide   Boolean @default(true) @map("can_hide") // API permission
  canDelete Boolean @default(false) @map("can_delete") // API permission
  canReply  Boolean @default(true) @map("can_reply")
  canLike   Boolean @default(true) @map("can_like")

  // Engagement
  likeCount     Int     @default(0) @map("like_count")
  replyCount    Int     @default(0) @map("reply_count")
  isLikedByPage Boolean @default(false) @map("is_liked_by_page")

  // Heuristic categorization (complaint > question > other > tag) for
  // priority sorting in the inbox; rank mirrors category for cheap ORDER BY
  category     String?
  categoryRank Int     @default(2) @map("category_rank")

  // Agent workflow
  status         SocialCommentStatus @default(NEW)
  assignedUserId String?             @map("assigned_user_id")
  internalLabel  String?             @map("internal_label") // spam, important, etc.
  notes          String? // Internal notes

  // Pre-generated AI reply draft (worker fills for NEW customer comments)
  aiDraft   String?   @map("ai_draft") @db.Text
  aiDraftAt DateTime? @map("ai_draft_at")

  // Raw data backup
  rawPayload Json? @map("raw_payload")

  // Timestamps
  commentedAt DateTime @map("commented_at") // When comment was made
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  account    SocialAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  object     SocialObject      @relation(fields: [objectId], references: [id], onDelete: Cascade)
  parent     SocialComment?    @relation("CommentReplies", fields: [parentId], references: [id])
  replies    SocialComment[]   @relation("CommentReplies")
  ruleRuns   SocialRuleRun[]
  actionLogs SocialActionLog[]

  @@unique([platform, externalId])
  @@index([objectId])
  @@index([accountId])
  @@index([parentId])
  @@index([threadRootId])
  @@index([status])
  @@index([hidden])
  @@index([commentedAt])
  @@index([internalLabel])
  @@map("social_comments")
}

// ============================================================================
// Social Automation Rules
// ============================================================================

enum SocialRuleTrigger {
  COMMENT_CREATED
  COMMENT_UPDATED
}

enum SocialRuleAction {
  HIDE_COMMENT // Facebook only
  UNHIDE_COMMENT // Facebook only
  DELETE_COMMENT // If permitted
  LIKE_COMMENT
  ADD_LABEL // Internal label
  SET_STATUS // Set to specific status
  ASSIGN_TO_AGENT
  NOTIFY // In-app notification
}

// Automation rule definition
model SocialRule {
  id String @id @default(cuid())

  // Rule metadata
  name        String
  description String?
  enabled     Boolean @default(true)
  priority    Int     @default(100) // Lower = higher priority (runs first)

  // Scope
  platforms SocialPlatform[] // Which platforms this applies to
  accounts  SocialAccount[]  @relation("RuleSocialAccounts") // Specific accounts (empty = all)

  // Trigger
  triggers SocialRuleTrigger[]

  // Conditions (JSON for flexibility)
  // Structure: { matchType: "all" | "any", conditions: [...] }
  // Each condition: { type: "keyword" | "regex" | "has_url" | etc., value: "...", negated: false }
  conditions Json

  // Actions (ordered array)
  // Each action: { type: "hide_comment" | "delete_comment" | etc., params: {...} }
  actions Json

  // Safety features
  dryRun        Boolean @default(false) @map("dry_run") // Log only, don't act
  requireReview Boolean @default(false) @map("require_review") // Flag instead of act
  stopOnMatch   Boolean @default(true) @map("stop_on_match") // Stop processing other rules

  // Rate limiting
  maxActionsPerHour Int?      @map("max_actions_per_hour")
  actionsThisHour   Int       @default(0) @map("actions_this_hour")
  lastHourReset     DateTime? @map("last_hour_reset")

  // Stats
  matchCount  Int       @default(0) @map("match_count")
  actionCount Int       @default(0) @map("action_count")
  lastMatchAt DateTime? @map("last_match_at")

  // Admin
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  runs SocialRuleRun[]

  @@index([enabled])
  @@index([priority])
  @@map("social_rules")
}

// Audit log for each rule evaluation/execution
model SocialRuleRun {
  id        String @id @default(cuid())
  ruleId    String @map("rule_id")
  commentId String @map("comment_id")

  // Match result
  matched      Boolean
  matchDetails Json?   @map("match_details") // Which conditions matched

  // Execution
  actionsExecuted Json?   @map("actions_executed") // What was done
  allSucceeded    Boolean @default(true) @map("all_succeeded")
  errors          Json? // Any errors during execution

  // Mode
  wasDryRun  Boolean @default(false) @map("was_dry_run")
  wasFlagged Boolean @default(false) @map("was_flagged") // Flagged for review

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  rule    SocialRule    @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  comment SocialComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([commentId])
  @@index([matched])
  @@index([createdAt])
  @@map("social_rule_runs")
}

// ============================================================================
// Social Action Log (audit trail for all actions)
// ============================================================================

enum SocialActionType {
  REPLY
  LIKE
  UNLIKE
  HIDE
  UNHIDE
  DELETE
  LABEL_ADDED
  LABEL_REMOVED
  STATUS_CHANGED
  ASSIGNED
  UNASSIGNED
  NOTE_ADDED
  SYNCED
}

model SocialActionLog {
  id        String  @id @default(cuid())
  commentId String? @map("comment_id") // Can be null for account-level actions

  actionType SocialActionType @map("action_type")

  // Actor
  actorType String  @map("actor_type") // "user" | "system" | "automation"
  actorId   String? @map("actor_id") // User ID or Rule ID
  actorName String? @map("actor_name")

  // Action details
  details Json? // Action-specific data

  // API interaction (for auditing)
  apiRequest  Json?   @map("api_request") // What was sent (tokens redacted)
  apiResponse Json?   @map("api_response") // What was received
  apiSuccess  Boolean @default(true) @map("api_success")
  apiError    String? @map("api_error")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  comment SocialComment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([commentId])
  @@index([actionType])
  @@index([actorType])
  @@index([createdAt])
  @@map("social_action_logs")
}

// ============================================================================
// Social Sync Jobs (tracking background sync state)
// ============================================================================

model SocialSyncJob {
  id        String @id @default(cuid())
  accountId String @map("account_id")

  status      SyncJobStatus @default(PENDING)
  startedAt   DateTime?     @map("started_at")
  completedAt DateTime?     @map("completed_at")

  commentsProcessed Int     @default(0) @map("comments_processed")
  newComments       Int     @default(0) @map("new_comments")
  errorMessage      String? @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([accountId])
  @@index([status])
  @@map("social_sync_jobs")
}

// Database backups stored in DB for persistence on Railway
model DatabaseBackup {
  id        String   @id @default(cuid())
  filename  String
  size      Int // Size in bytes
  data      Bytes // The actual SQL backup content (compressed)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("database_backups")
}

// ============================================================================
// AI Triage + Pre-generated Drafts (background worker pipeline)
// ============================================================================

enum TriageIntent {
  SIZE_EXCHANGE
  SHIPPING_STATUS
  ADDRESS_UPDATE
  CANCELLATION
  // Wrong / damaged / defective item received, print or quality complaint
  ORDER_ISSUE
  // Wants money back or to return without an exchange
  RETURN_REFUND
  // A discount/promo code did not apply or calculated wrong; "I didn't get my discount"
  DISCOUNT
  // Pre-sale question: sizing advice, materials, availability, shipping cost
  PRODUCT_QUESTION
  // Praise / thanks, usually no action needed
  POSITIVE_FEEDBACK
  // Asks to unsubscribe / be removed from the email list / "STOP"
  UNSUBSCRIBE
  // Wholesale / bulk / reseller inquiry - routes to the wholesale reply
  WHOLESALE
  // Vendor marketing, SaaS/SEO/B2B pitch, or internal system notification -
  // not a customer message; no reply draft is generated
  SPAM
  OTHER
}

enum AiDraftStatus {
  PENDING
  READY
  FAILED
  STALE
  // Intent needs an action first (e.g. size exchange) - draft once it's done
  AWAITING_ACTION
}

model ThreadTriage {
  id       String @id @default(cuid())
  threadId String @unique @map("thread_id")

  intent     TriageIntent
  confidence Float
  // Extracted entities: { requestedSize, lineItemHint, newAddress {...},
  // orderNumber, wantsRefund, sentiment }
  entities   Json?

  // Latest inbound message this classification is based on
  classifiedMessageId String? @map("classified_message_id")
  model               String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([intent])
  @@map("thread_triage")
}

model AiDraft {
  id       String @id @default(cuid())
  threadId String @unique @map("thread_id")

  // Inbound message this draft answers (staleness detection)
  forMessageId String? @map("for_message_id")

  body               String        @db.Text
  status             AiDraftStatus @default(PENDING)
  warnings           Json?
  intent             TriageIntent?
  model              String?
  contextRefreshedAt DateTime?     @map("context_refreshed_at")
  error              String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("ai_drafts")
}

// ============================================================================
// Judge.me review drafts (low-star reviews get a pre-written public reply)
// ============================================================================

enum ReviewDraftStatus {
  PENDING
  READY
  FAILED
  // Replied or hidden - no longer needs attention
  HANDLED
}

model ReviewDraft {
  id       String @id @default(cuid())
  // Judge.me review id
  reviewId Int    @unique @map("review_id")

  // Snapshot of the review for display without re-fetching Judge.me
  rating          Int
  reviewerName    String?   @map("reviewer_name")
  reviewTitle     String?   @map("review_title")
  reviewBody      String?   @map("review_body") @db.Text
  productTitle    String?   @map("product_title")
  reviewCreatedAt DateTime? @map("review_created_at")

  // The AI-drafted public reply
  body   String            @db.Text
  status ReviewDraftStatus @default(PENDING)
  model  String?
  error  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("review_drafts")
}

// ============================================================================
// Printify order relinking (recreated orders -> original Shopify order)
// Printify has no order-update endpoint and cancelled orders cannot be
// natively re-linked, so the tool tracks the mapping and pushes fulfillment
// + tracking back onto the original Shopify order when the new order ships.
// ============================================================================

enum RelinkReason {
  ADDRESS_CHANGE
  REPLACEMENT
  REROUTE
  ITEM_CHANGE
}

enum RelinkStatus {
  PENDING
  IN_PRODUCTION
  FULFILLED_PUSHED
  FAILED
  CANCELLED
}

// ============================================================================
// Store knowledge injected into AI reply drafts
// Brand voice + avatar (pushed from the Summit Soul AI project) and the
// store's own Shopify pages + policies (pulled by the worker). Gives the
// drafting model accurate answers to policy/FAQ/sizing questions.
// ============================================================================

enum KnowledgeType {
  BRAND
  AVATAR
  SHOPIFY_PAGE
  SHOPIFY_POLICY
  SHOPIFY_CATALOG
  CUSTOM
}

model KnowledgeSource {
  id        String        @id @default(cuid())
  type      KnowledgeType
  // Stable upsert key, e.g. "brand-voice", "avatar", "page:faq", "policy:refund_policy"
  key       String        @unique
  title     String
  content   String        @db.Text
  enabled   Boolean       @default(true)
  source    String? // origin url or file path, for reference
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([type])
  @@map("knowledge_sources")
}

model OrderRelink {
  id String @id @default(cuid())

  // The NEW Printify order created via API
  printifyOrderId         String  @unique @map("printify_order_id")
  // The cancelled Printify order it replaces
  originalPrintifyOrderId String? @map("original_printify_order_id")
  // The ORIGINAL Shopify order that should receive fulfillment/tracking
  shopifyOrderId          String  @map("shopify_order_id")
  shopifyOrderName        String? @map("shopify_order_name")

  reason RelinkReason
  status RelinkStatus @default(PENDING)

  trackingNumber      String?   @map("tracking_number")
  carrier             String?
  fulfillmentPushedAt DateTime? @map("fulfillment_pushed_at")
  error               String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([shopifyOrderId])
  @@map("order_relinks")
}

// Customer-sourced design ideas: comments/emails tagged as inspiration for
// new shirt designs, collected for the weekly design batch
model DesignIdea {
  id         String   @id @default(cuid())
  text       String   @db.Text
  source     String // FACEBOOK | INSTAGRAM | EMAIL | REVIEW | MANUAL
  authorName String?  @map("author_name")
  permalink  String?
  sourceId   String?  @map("source_id") // e.g. the social comment id
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("design_ideas")
}

// Operator-applied resolution for a late order (Printify order id). Lets the VA
// mark a late delivery as solved (e.g. Printify refunded it, handled manually)
// with an optional note, moving it to the Solved tab in the Late deliveries view.
model LateOrderResolution {
  id                 String   @id @default(cuid())
  printifyOrderId    String   @unique @map("printify_order_id")
  // Legacy manual-solved flag - no longer drives resolution (kept for history).
  solved             Boolean  @default(true)
  // Whether the customer was refunded (manual track; null = not decided).
  // Combined with auto-detected Shopify refunds and replacements.
  customerRefunded   Boolean? @map("customer_refunded")
  // Whether Printify refunded us for the order (null = not decided yet).
  refundedByPrintify Boolean? @map("refunded_by_printify")
  // Free-text notes - informational only, never resolves an order.
  note               String?
  resolvedBy         String?  @map("resolved_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("late_order_resolutions")
}

// Single-use, hashed, expiring tokens for the customer-facing self-service
// portal (cancel / change address before production). The raw token only ever
// lives in the magic link emailed to the address ON the order; we store its
// SHA-256 hash. Ownership proof = the customer receives the email. Consuming a
// token is atomic so an action can never run twice from one link.
model SelfServiceToken {
  id               String    @id @default(cuid())
  tokenHash        String    @unique @map("token_hash") // sha256(rawToken)
  purpose          String // CANCEL (future: CHANGE_ADDRESS)
  shopifyOrderId   String    @map("shopify_order_id") // gid://shopify/Order/...
  shopifyOrderName String    @map("shopify_order_name") // "#18100"
  email            String // lowercased email on the order
  printifyOrderId  String?   @map("printify_order_id") // resolved at request time, if linked
  requestIp        String?   @map("request_ip")
  expiresAt        DateTime  @map("expires_at")
  consumedAt       DateTime? @map("consumed_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("self_service_tokens")
}

enum EscalationResolution {
  REPLACEMENT
  REFUND
}

enum EscalationStatus {
  PENDING
  DONE
}

// A defect / lost-package case that the operator has answered to the customer
// and now needs to action on Printify (replacement or refund), handled in bulk
// from the Printify Escalations section of Needs Attention. threadId is a plain
// id (no relation) to keep the migration light.
model PrintifyEscalation {
  id              String               @id @default(cuid())
  threadId        String?              @map("thread_id")
  orderNumber     String               @map("order_number") // "#17298"
  shopifyOrderId  String?              @map("shopify_order_id") // gid, for linkout
  printifyOrderId String?              @map("printify_order_id") // for linkout + reprint detection
  customerName    String?              @map("customer_name")
  customerEmail   String?              @map("customer_email")
  resolution      EscalationResolution
  issue           String               @db.Text
  photoUrls       String[]             @map("photo_urls")
  status          EscalationStatus     @default(PENDING)
  createdAt       DateTime             @default(now()) @map("created_at")
  createdBy       String?              @map("created_by")
  resolvedAt      DateTime?            @map("resolved_at")
  resolvedBy      String?              @map("resolved_by")

  @@index([status])
  @@index([threadId])
  @@map("printify_escalations")
}
